# ============================================================
# LatestWorld.in — Environment Variables
# ============================================================

# ── CLOUDFLARE PAGES (set in Pages → Settings → Env Variables)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── GITHUB ACTIONS SECRETS (set in repo → Settings → Secrets → Actions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API Keys — Where to get each one:
#
# COINGECKO_API_KEY
#   → coingecko.com → Sign up free → Developers Dashboard
#   → "Add New Key" → name it latestworld → copy key
#
# GNEWS_API_KEY
#   → gnews.io → Sign up free → Dashboard → copy API key
#   → Free: 100 requests/day
#
# GH_TOKEN (use GH_TOKEN not GITHUB_TOKEN to avoid conflicts)
#   → github.com/settings/tokens → "Generate new token (classic)"
#   → Name: latestworld-bot → Scope: public_repo only → copy
#
# PRODUCTHUNT_TOKEN
#   → producthunt.com → Sign in → producthunt.com/v2/oauth/applications
#   → "Add an Application" → Developer Token tab → copy
#
# ADZUNA_APP_ID + ADZUNA_APP_KEY
#   → developer.adzuna.com → Register → Create app: latestworld
#   → Copy App ID and App Key separately
#
# CLOUDFLARE_PAGES_DEPLOY_HOOK
#   → Cloudflare → Pages → latestworld → Settings → Builds → Deploy Hooks
#   → Add hook: name "cron-trigger", branch "main" → copy URL

COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxx
GNEWS_API_KEY=your-gnews-key
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
PRODUCTHUNT_TOKEN=your-ph-token
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
CLOUDFLARE_PAGES_DEPLOY_HOOK=https://api.cloudflare.com/client/v4/pages/webhooks/deploy_hooks/XXXX
